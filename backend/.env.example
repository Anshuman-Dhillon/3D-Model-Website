# Server
PORT=8000
NODE_ENV=development

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/3dmodeller?retryWrites=true&w=majority

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))")
ACCESS_SECRET_TOKEN=your_access_secret_here
REFRESH_SECRET_TOKEN=your_refresh_secret_here

# Bcrypt
SALT_ROUNDS=10

# AWS S3 Configuration — for model file & thumbnail storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
S3_BUCKET_NAME=3dmodeller-assets

# Stripe — for payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google OAuth — client ID from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# SMTP Email (Nodemailer) — for support form confirmation emails
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SUPPORT_EMAIL=support@yourdomain.com
